# Neon Postgres connection string.
DATABASE_URL="postgres://user:password@host/db?sslmode=require"

# Auth.js session secret. Use a long random value.
AUTH_SECRET="replace-with-random-secret-at-least-16-chars"

# Single administrator account.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD_HASH="replace-with-bcrypt-hash"

# Bearer token required by /api/cron/fetch.
CRON_SECRET="replace-with-random-secret-at-least-16-chars"
